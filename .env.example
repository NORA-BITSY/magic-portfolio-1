# Site — required for production metadata and sitemap
NEXT_PUBLIC_SITE_URL=https://paraileial.com
NEXT_PUBLIC_SITE_NAME=Practical AI Systems
NEXT_PUBLIC_SITE_DESCRIPTION=Practical AI workflows, templates, automations, and systems for small business owners.

# Founder / contact
NEXT_PUBLIC_FOUNDER_NAME=Patrick
NEXT_PUBLIC_CONTACT_EMAIL=hello@paraileial.com

# Email capture (Mailchimp, Kit/ConvertKit, Beehiiv form action URL)
NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=
# Set to true to hide newsletter forms until provider is connected
NEXT_PUBLIC_NEWSLETTER_DISABLED=false

# Booking (Cal.com, Calendly, SavvyCal — full booking page URL)
NEXT_PUBLIC_BOOKING_URL=

# Store checkout — one URL per product (Lemon Squeezy checkout links)
NEXT_PUBLIC_CHECKOUT_SMALL_BUSINESS_PROMPT_LIBRARY=
NEXT_PUBLIC_CHECKOUT_AI_ADMIN_STARTER_KIT=
NEXT_PUBLIC_CHECKOUT_LEAD_FOLLOW_UP_AUTOMATION_KIT=
NEXT_PUBLIC_CHECKOUT_CONTENT_REPURPOSING_WORKFLOW_KIT=
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_URL=

# CTAs (optional overrides)
NEXT_PUBLIC_PRIMARY_CTA_LABEL=Get the Free AI Workflow Checklist
NEXT_PUBLIC_PRIMARY_CTA_HREF=/free-checklist
NEXT_PUBLIC_SECONDARY_CTA_LABEL=Browse Templates & Toolkits
NEXT_PUBLIC_SECONDARY_CTA_HREF=/store

# Analytics — choose one or leave blank
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Social — only set real profile URLs
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# Optional: password-protect draft routes (not used for public marketing pages)
PAGE_ACCESS_PASSWORD=

# Strict content audit in CI (set to 1 in production pipelines)
# AUDIT_STRICT=1
